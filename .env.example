# Copia questo file in .env e compila i valori prima del deploy
# Il file .env NON va mai committato su git

# Obbligatoria: stringa random di almeno 32 caratteri
# Genera con: openssl rand -hex 32
JWT_SECRET_KEY=CAMBIA_CON_UNA_STRINGA_RANDOM_LUNGA

# Credenziali accesso legacy (admin e viewer)
LEGACY_ADMIN_PWD=CAMBIA_CON_PASSWORD_ADMIN
LEGACY_VIEWER_PWD=CAMBIA_CON_PASSWORD_VIEWER

# Google AI (opzionale, solo se usi le funzioni AI)
GOOGLE_API_KEY=
