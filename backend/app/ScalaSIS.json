      "id": "sis_supports_intensity_scale",
      "nome": "Supports Intensity Scale (SIS)",
      "sottotitolo": "Valutazione dell'intensità dei bisogni di sostegno",
      "versione": "Adulti (>16 anni) – Edizione italiana",
      "autori": "James R. Thompson, Brian R. Bryant, Edward M. Campbell, Ellis M. (Pat) Craig, Carolyn M. Hughes, David A. Rotholz, Robert L. Schalock, Wayne P. Silverman, Marc J. Tassé, Michael L. Wehmeyer",
      "edizione_italiana": "Mauro Leoni e Luigi Croce",
      "anno": 2007,
      "editore": "Vannini Editrice",
      "target": "Persone con disabilità intellettiva (ritardo mentale) e disabilità dello sviluppo correlate",
      "eta": "≥16 anni (fuori dal sistema scolastico) o ≥18 anni",
      "informatori": "Professionisti con esperienza (laurea + anni di esperienza) che conoscono la persona da almeno 3 mesi; possono essere anche familiari",
      "intervistatore": "Professionista con laurea di 4 anni, esperienza nel settore",
      "tempo_somministrazione": "30 minuti circa",
      "proprieta_psicometriche": {
        "consistenza_interna_totale": 0.99,
        "alpha_dominio_min": 0.94,
        "alpha_dominio_max": 0.97,
        "campione_validazione": 1306,
        "media_indice_sis": 100,
        "ds_indice_sis": 15
      },
      "struttura_punteggi": {
        "punteggi_item": "ciascun item valuta Frequenza (0-4), Durata quotidiana (0-4), Tipo sostegno (0-4). Punteggio grezzo item = F + D + T (max 12, tranne item con F max=3 come A3 → max 11)",
        "punteggio_grezzo_dominio": "somma dei punteggi grezzi degli item del dominio (range variabile per dominio, vedi tabella)",
        "punteggio_standard_dominio": "conversione tramite tabella (media=10, DS=3, range 1-20)",
        "indice_sis": "somma dei 6 punteggi standard → conversione tramite tabella (media=100, DS=15, range 60-143)",
        "percentili": "disponibili sia per domini che per indice SIS"
      },
      "note_operative": [
        "Compilare TUTTI gli item, anche se la persona non svolge l'attività (ipotizzare i sostegni necessari)",
        "Non fare riferimento ai servizi attualmente disponibili o forniti",
        "Valutare i sostegni necessari per svolgere efficacemente l'attività",
        "Se la persona usa tecnologia assistiva, valutarla con tale tecnologia in uso",
        "Per attività con frequenza oraria non realistica, il valore 4 è cancellato (es. preparare i pasti)"
      ]
    },
    "dimensioni_sostegno": {
      "legenda_frequenza": {
        "0": "nessuna o meno di una volta al mese",
        "1": "almeno una volta al mese, ma meno di una volta alla settimana",
        "2": "almeno una volta alla settimana, ma meno di una volta al giorno",
        "3": "almeno una volta al giorno, ma meno di una volta all'ora",
        "4": "ogni ora o con maggior frequenza"
